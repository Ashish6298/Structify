{
  "name": "structify-cli",
  "version": "1.0.0",
  "description": "Interactive CLI for generating production-ready project architectures",
  "main": "dist/index.js",
  "bin": {
    "structify": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@structify/core": "*",
    "@structify/logger": "*",
    "commander": "^12.1.0"
  },
  "devDependencies": {}
}
