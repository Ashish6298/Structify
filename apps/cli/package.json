{
  "name": "structify-cli",
  "version": "1.0.0",
  "description": "Interactive CLI for generating production-ready project architectures",
  "main": "dist/index.js",
  "bin": {
    "structify": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ashish6298/Structify.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@structify/core": "*",
    "@structify/logger": "*"
  }
}
