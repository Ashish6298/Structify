{
  "name": "ecommerce-vite-express",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "dev": "npm run dev:web",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dev:web": "vite",
    "dev:api": "ts-node-dev src/index.ts",
    "build:api": "tsc --project tsconfig.server.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\""
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "express": "^4.19.0",
    "mongoose": "^8.4.0"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "prettier": "^3.2.0"
  }
}
