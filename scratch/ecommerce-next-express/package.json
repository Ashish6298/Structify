{
  "name": "ecommerce-next-express",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "dev": "npm run dev:web",
    "build": "next build",
    "start": "next start",
    "dev:web": "next dev",
    "dev:api": "ts-node-dev src/index.ts",
    "build:api": "tsc --project tsconfig.server.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "eslint \"app/**/*.{ts,tsx}\"",
    "format": "prettier --write \"app/**/*.{ts,tsx,css,html,json}\""
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "express": "^4.19.0",
    "@prisma/client": "^5.15.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "prisma": "^5.15.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "prettier": "^3.2.0"
  }
}
